labelFunc0282_0790:
	if (!(var0002 == 0x0055)) goto labelFunc0282_07A6;
	message("~~ ~~HOW TO CONQUER THE WORLD IN THREE EASY STEPS~~ ~~by Maximillian the Amazingly Mean*");
