	case "the Psyche returns" attend labelFunc009A_03B7:
	UI_show_npc_face(0xFEE2, 0x0000);
	message("\"Could this possibly be true?\" Erethian's blind eyes light up with unabashed glee. \"What an opportunity I have here.\"");
