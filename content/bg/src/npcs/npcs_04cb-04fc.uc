	UI_add_answer("Blorn");
labelFunc04D1_00DD:
	UI_remove_answer("problems");
labelFunc04D1_00E4:
	case "gargoyles" attend labelFunc04D1_00FD:
	message("\"I don't trust them any more than thou dost, ");
