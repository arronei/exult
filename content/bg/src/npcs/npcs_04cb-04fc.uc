labelFunc04E6_011E:
	if (!gflags[0x0006]) goto labelFunc04E6_0128;
	message("\"Ah, thou art a Fellowship member. Thou wilt surely find thy reward at these tables!\" Gordy winks and nudges you, then guffaws loudly.");
