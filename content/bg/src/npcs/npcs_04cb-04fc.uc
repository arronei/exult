	UI_add_answer("Budo");
labelFunc04E7_029F:
	if (!gflags[0x02AB]) goto labelFunc04E7_02AC;
	UI_add_answer("Glenno");
labelFunc04E7_02AC:
	if (!gflags[0x02AA]) goto labelFunc04E7_02B9;
	UI_add_answer("Wench");
labelFunc04E7_02B9:
