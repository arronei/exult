	abort;
	goto labelFunc04F8_0246;
labelFunc04F8_0228:
	message("\"Before thou dost depart, let me show thee a few of my trinkets. Here is my...\"");
	say();
	UI_push_answers();
	UI_add_answer(["moon", "sextant", "kite", "crystals", "nothing"]);
labelFunc04F8_0246:
	case "nothing" attend labelFunc04F8_0252:
