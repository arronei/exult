labelFunc04E7_0152:
	UI_add_answer("Fallen Virgin");
labelFunc04E7_0159:
	case "food" attend labelFunc04E7_0173:
	message("\"We serve a good plate of slop, if I do say so myself! That Silverleaf is something. Thou shouldst try that.\"");
