	say();
labelFunc0431_00E5:
	goto labelFunc0431_00F3;
labelFunc0431_00E8:
	message("\"Please return during daylight hours if thou dost wish to train.\"");
	say();
	UI_remove_answer("train");
labelFunc0431_00F3:
