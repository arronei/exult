labelFunc0409_03DD:
	message("\"Sir Dupre, hast thou finished thy studies yet?\"*");
	say();
	UI_show_npc_face(0xFFFC, 0x0000);
	message("Dupre looks confounded. \"My studies, milady?\"*");
	say();
	UI_show_npc_face(0xFFF7, 0x0000);
