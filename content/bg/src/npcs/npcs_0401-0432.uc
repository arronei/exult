	abort;
	goto labelFunc0427_003F;
labelFunc0427_003A:
	message("\"I must get to my performance at The Blue Boar! The Avatars are playing tonight!\"*");
	say();
	abort;
labelFunc0427_003F:
	UI_add_answer(["name", "job", "bye"]);
