	message("\"Well! Thy reputation precedes thee! The Avatar in person! Word has spread that thou wert in Britain!\"");
	say();
	gflags[0x00AA] = true;
	goto labelFunc0429_00B9;
labelFunc0429_008D:
	if (!(var0002 == 0x0000)) goto labelFunc0429_00B5;
	var0004 = Func08F7(0xFFD5);
