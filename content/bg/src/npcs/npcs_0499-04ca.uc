	var0004 = var0003;
	gflags[0x022E] = true;
labelFunc04AA_00E0:
	if (!(var0005 == var0001)) goto labelFunc04AA_00F7;
	message("\"Thou art a most pathetic little worm. Really, all this Avatar nonsense is nothing more than a sad plea for attention.\"*");
	say();
	gflags[0x0223] = true;
	gflags[0x0215] = true;
	abort;
labelFunc04AA_00F7:
