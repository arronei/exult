	goto labelFunc04BF_009D;
labelFunc04BF_007C:
	message("\"Of course thou art! And I am the evil spirit of Mondain, come back to wreak havoc over all Britannia. Funny, thou dost not look like an Avatar -- thou dost look like a fool.");
