labelFunc0457_0214:
	if (!(var0004 > var0005)) goto labelFunc0457_022B;
	message("\"Thou hast ");
	message(var0004);
	message(" in thy party. I am afraid thou does not have enough Caddellite for me to make that many helmets.\"");
