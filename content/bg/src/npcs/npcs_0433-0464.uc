	UI_add_answer(["magic", "spells", "reagents"]);
labelFunc044A_00A1:
	case "magic" attend labelFunc044A_00C2:
	if (!(!gflags[0x0003])) goto labelFunc044A_00B7;
	message("\"I do not understand what is wrong. My magic does not work so well anymore.\"");
