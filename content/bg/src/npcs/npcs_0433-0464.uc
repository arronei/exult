	if (!(var0005 == 0x0001)) goto labelFunc0457_0250;
	message("Zorn takes the Caddellite from you and begins his work.");
	say();
	goto labelFunc0457_025A;
labelFunc0457_0250:
	message("\"Thou hast ");
	message(var0005);
	message(" Caddellite chunks. That is how many helmets I can make for thee.\"");
