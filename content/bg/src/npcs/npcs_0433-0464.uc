	if (!(!gflags[0x00BF])) goto labelFunc043E_003A;
	message("You see a filthy beggar who flashes you a grin as though you were his best friend in the whole world.");
	say();
	gflags[0x00BF] = true;
	goto labelFunc043E_0044;
labelFunc043E_003A:
	message("\"Hello again, ");
