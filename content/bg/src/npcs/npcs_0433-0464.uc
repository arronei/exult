	say();
	message("\"Wouldst thou like to hear the gold joke again?\"");
	say();
	var000D = Func090A();
	if (!var000D) goto labelFunc043E_0374;
	message("\"Now listen carefully...\"");
	say();
	var000E = UI_remove_party_items(0x0001, 0x0284, 0xFE99, 0xFE99, true);
